{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run web:export",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/transfer-planner",
      "destination": "/resources/transfer-planner",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/resources/transfer-planner/:college/:campus/:major",
      "destination": "/resources/transfer-planner/[college]/[campus]/[major]"
    },
    {
      "source": "/college/:collegeId",
      "destination": "/college/[collegeId]"
    }
  ]
}
