# @generated by scripts/dev/generate-env-template.cjs
# GatorGuide client environment template
# Copy this file to .env and fill in local values. Do not commit .env.
#
# Legacy global stub-mode env toggles are intentionally absent.
# Sample and fallback behavior is controlled in code, not this template.

# Firebase client config
# Create a Firebase web app and copy these values from Project settings.
# Enable Authentication and Firestore before using sign-in flows.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# College Scorecard client key
# Optional, but live college search requires an api.data.gov key.
EXPO_PUBLIC_COLLEGE_SCORECARD_KEY=

# Firebase Functions client gateways
# Gemini secrets and gateway quotas are configured in functions/.env.example.
# These values only tell the app which callable Functions to invoke.
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
EXPO_PUBLIC_AI_GATEWAY_FUNCTION_NAME=geminiGateway
EXPO_PUBLIC_AI_TIMEOUT_MS=15000
EXPO_PUBLIC_OPPORTUNITY_GATEWAY_FUNCTION_NAME=opportunityGateway
EXPO_PUBLIC_OPPORTUNITY_TIMEOUT_MS=20000

# Support and error reporting
# Leave webhook values blank to use the Firebase project default when available.
EXPO_PUBLIC_SUPPORT_ERROR_LOG_WEBHOOK=
EXPO_PUBLIC_SUPPORT_MESSAGE_WEBHOOK=
EXPO_PUBLIC_ERROR_LOG_QUEUE_MAX=30

# OAuth client ids
# Optional for local development if email/password sign-in is enough.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=

# Expo account
# Optional; used by Expo auth redirect helpers.
EXPO_PUBLIC_EXPO_USERNAME=

# Dev-only diagnostics
# Set to 1 only while debugging Course Planner render internals.
EXPO_PUBLIC_ENABLE_COURSE_PLANNER_RENDER_AUDITS=
