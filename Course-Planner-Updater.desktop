[Desktop Entry]
Type=Application
Name=Course Planner Updater
Comment=Download Gator Guide if needed, then run the course planner update menu
Exec=sh -c "launcher=\"\$1\"; if [ -n \"\$launcher\" ]; then launcher_dir=\"\$(dirname \"\$launcher\")\"; else launcher_dir=\"\$(pwd)\"; fi; repo_name=\"GatorGuide\"; repo_url=\"https://github.com/MarsLuay/GatorGuide.git\"; repo_dir=\"\$launcher_dir\"; runner=\"\$repo_dir/Course-Planner-Updater.app/Contents/Resources/course-planner-updater.sh\"; log(){ printf \"%%s %%s\\n\" \"[Course-Planner-Updater]\" \"\$*\"; }; fail(){ printf \"%%s %%s\\n\" \"[Course-Planner-Updater]\" \"\$*\" >&2; exit 1; }; command_exists(){ command -v \"\$1\" >/dev/null 2>&1; }; run_with_privilege(){ if [ \"\$(id -u)\" -eq 0 ]; then \"\$@\"; elif command_exists sudo; then sudo \"\$@\"; else fail \"Need elevated privileges to run: \$*\"; fi; }; install_git(){ if command_exists apt-get; then log \"Git was not found. Installing Git with apt...\"; run_with_privilege apt-get update; run_with_privilege apt-get install -y git; elif command_exists dnf; then log \"Git was not found. Installing Git with dnf...\"; run_with_privilege dnf install -y git; elif command_exists yum; then log \"Git was not found. Installing Git with yum...\"; run_with_privilege yum install -y git; elif command_exists pacman; then log \"Git was not found. Installing Git with pacman...\"; run_with_privilege pacman -Sy --noconfirm git; elif command_exists zypper; then log \"Git was not found. Installing Git with zypper...\"; run_with_privilege zypper install -y git; elif command_exists apk; then log \"Git was not found. Installing Git with apk...\"; run_with_privilege apk add --no-cache git; else fail \"Git is missing and no supported package manager was found. Install Git from https://git-scm.com/downloads and run this file again.\"; fi; command_exists git || fail \"Git installation finished, but git is still unavailable in this shell.\"; log \"Git finished installing successfully.\"; }; ensure_git(){ if command_exists git; then log \"Git is already installed.\"; else install_git; fi; }; if [ ! -f \"\$runner\" ]; then clone_root=\"\$launcher_dir/\$repo_name\"; if [ -f \"\$clone_root/Course-Planner-Updater.app/Contents/Resources/course-planner-updater.sh\" ]; then repo_dir=\"\$clone_root\"; else log \"Gator Guide was not found next to this launcher.\"; ensure_git; [ ! -e \"\$clone_root\" ] || fail \"Cannot clone into \$clone_root because that path already exists.\"; log \"Cloning Gator Guide into \$clone_root...\"; git clone \"\$repo_url\" \"\$clone_root\" || fail \"Could not clone the repo from \$repo_url.\"; repo_dir=\"\$clone_root\"; fi; runner=\"\$repo_dir/Course-Planner-Updater.app/Contents/Resources/course-planner-updater.sh\"; fi; [ -f \"\$runner\" ] || fail \"The repo was found, but the course planner launcher script is missing at \$runner.\"; exec bash \"\$runner\"" sh "%k"
Terminal=true
Categories=Development;
