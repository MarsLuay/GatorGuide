{
  "name": "gator-guide",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node scripts/start-expo.cjs",
    "start:tunnel": "node scripts/start-expo.cjs --mode=tunnel",
    "start:lan": "node scripts/start-expo.cjs --mode=lan",
    "start:offline": "node scripts/start-expo.cjs --mode=offline",
    "catalog:add": "node scripts/add-catalog-item.cjs",
    "size:publish": "node scripts/report-publish-size.cjs",
    "android": "expo run:android",
    "android:sdk": "cmd /c scripts/run-android.cmd",
    "ios": "expo run:ios",
    "web": "node scripts/start-expo.cjs --web",
    "web:tunnel": "node scripts/start-expo.cjs --web --mode=tunnel",
    "web:lan": "node scripts/start-expo.cjs --web --mode=lan",
    "web:offline": "node scripts/start-expo.cjs --web --mode=offline",
    "qa:windows:build": "npx expo export --platform web --output-dir .tools/qa-web",
    "qa:windows:screenshots": "node .tools/windows-qa.mjs",
    "qa:windows:interactions": "node .tools/windows-interactions.mjs",
    "qa:windows:ci": "node scripts/run-windows-qa.cjs",
    "assets:brand": "node scripts/brand-assets.cjs",
    "assets:brand:verify": "node scripts/brand-assets.cjs --check",
    "lint": "expo lint",
    "test:firebase-rules": "node scripts/run-firebase-rules-tests.cjs",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "eas:ios": "npx eas build --platform ios --profile preview",
    "eas:android": "npx eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "^1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.22",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "nativewind": "^4.2.1",
    "pdfjs-dist": "^5.6.205",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-tools": "^15.11.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "flatted": "3.4.2",
    "node-forge": "1.4.0",
    "chokidar": {
      "picomatch": "2.3.2"
    },
    "jest-util": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    }
  },
  "private": true
}
