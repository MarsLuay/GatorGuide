# Firebase Functions local environment template
# Copy to .env.local for emulator work or set the same variables in the
# deployed Functions environment.

# Gemini server-side config
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000

# Free-tier protection
GEMINI_GLOBAL_DAILY_UNITS_LIMIT=250
GEMINI_AUTH_DAILY_UNITS_LIMIT=60
GEMINI_GUEST_DAILY_UNITS_LIMIT=12
GEMINI_RECOMMEND_BATCH_SIZE=12
GEMINI_MAX_CANDIDATES_PER_REQUEST=20

# Existing support email config
RESEND_API_KEY=
SUPPORT_FROM_EMAIL=onboarding@resend.dev
SUPPORT_MAX_BODY_BYTES=32768
SUPPORT_RATE_LIMIT_WINDOW_MS=3600000
SUPPORT_MESSAGE_ANONYMOUS_HOURLY_LIMIT=3
SUPPORT_MESSAGE_TRUSTED_HOURLY_LIMIT=10
SUPPORT_MESSAGE_IP_HOURLY_LIMIT=30
SUPPORT_MESSAGE_GLOBAL_HOURLY_LIMIT=300
SUPPORT_ERROR_LOG_ANONYMOUS_HOURLY_LIMIT=12
SUPPORT_ERROR_LOG_TRUSTED_HOURLY_LIMIT=60
SUPPORT_ERROR_LOG_IP_HOURLY_LIMIT=120
SUPPORT_ERROR_LOG_GLOBAL_HOURLY_LIMIT=1200
