# Copy this file to .env and fill in your values (do not commit .env)

# Set to false to use real Firebase (default in code is already false)
# EXPO_PUBLIC_USE_STUB_DATA=false

# Firebase: 若登录/注册失败，请到 Firebase 控制台检查：
# - 本地用 Google/Microsoft 登录若出现 "missing initial state"，请改用邮箱/密码登录
# 1. Authentication → Sign-in method → 启用 "Email/Password"
# 2. 若使用自己的项目，从 Project settings → Your apps 复制配置到下方
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=你的项目.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=你的项目ID
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=你的项目.firebasestorage.app
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=

# Other (optional)
# EXPO_PUBLIC_COLLEGE_SCORECARD_KEY=
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_SUPPORT_ERROR_LOG_WEBHOOK=
#
# OAuth (optional)
# EXPO_PUBLIC_MICROSOFT_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
